package com.adnexa.controller;

import java.util.List;

import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.security.core.Authentication;
import org.springframework.web.bind.annotation.GetMapping;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.PutMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RestController;

import com.adnexa.dto.ApplyCampaignRequest;
import com.adnexa.dto.CampaignResponse;
import com.adnexa.dto.InfluencerProfileRequest;
import com.adnexa.dto.InfluencerProfileResponse;
import com.adnexa.service.CampaignService;
import com.adnexa.service.InfluencerProfileService;

@RestController
@RequestMapping("/api/influencer")
public class InfluencerController {

    private final InfluencerProfileService influencerProfileService;
    private final CampaignService campaignService;

    public InfluencerController(
            InfluencerProfileService influencerProfileService,
            CampaignService campaignService) {

        this.influencerProfileService = influencerProfileService;
        this.campaignService = campaignService;
    }

    // Dashboard
    @PreAuthorize("hasRole('INFLUENCER')")
    @GetMapping("/dashboard")
    public String influencerDashboard() {
        return "Influencer Access";
    }

    // Create profile
    @PreAuthorize("hasRole('INFLUENCER')")
    @PostMapping("/profile")
    public String createProfile(@RequestBody InfluencerProfileRequest request) {
        return influencerProfileService.createProfile(request);
    }

    // Get profile
    @PreAuthorize("hasRole('INFLUENCER')")
    @GetMapping("/profile")
    public InfluencerProfileResponse getProfile() {
        return influencerProfileService.getProfile();
    }

    // Update profile
    @PreAuthorize("hasRole('INFLUENCER')")
    @PutMapping("/profile")
    public String updateProfile(@RequestBody InfluencerProfileRequest request) {
        return influencerProfileService.updateProfile(request);
    }

    // Campaign feed
    @PreAuthorize("hasRole('INFLUENCER')")
    @GetMapping("/campaigns")
    public List<CampaignResponse> getCampaignFeed() {
        return campaignService.getOpenCampaigns();
    }
    //apply
    @PreAuthorize("hasRole('INFLUENCER')")
    @PostMapping("/apply")
    public String applyToCampaign(
            Authentication authentication,
            @RequestBody ApplyCampaignRequest request) {

        String email = authentication.getName();

        return campaignService.applyToCampaign(email, request);
    }
}