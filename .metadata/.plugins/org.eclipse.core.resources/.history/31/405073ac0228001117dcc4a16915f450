package com.adnexa.service;

import java.time.LocalDateTime;
import java.util.List;
import org.springframework.stereotype.Service;
import com.adnexa.dto.*;
import com.adnexa.entity.*;
import com.adnexa.repository.*;

@Service
public class CampaignService {

    private final CampaignRepository campaignRepository;
    private final UserRepository userRepository;
    private final CampaignApplicationRepository campaignApplicationRepository;

    public CampaignService(CampaignApplicationRepository campaignApplicationRepository,
                           CampaignRepository campaignRepository,
                           UserRepository userRepository) {
        this.campaignApplicationRepository = campaignApplicationRepository;
        this.campaignRepository = campaignRepository;
        this.userRepository = userRepository;
    }

    public String createCampaign(String email, CampaignRequest request) {
        User advertiser = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("Advertiser not found"));

        // ✅ FIXED: was equals("ADVERTISER") on enum — must call .name()
        if (!advertiser.getRole().name().equals("ADVERTISER")) {
            throw new RuntimeException("Only advertisers can create campaigns");
        }

        Campaign campaign = Campaign.builder()
                .title(request.getTitle())
                .description(request.getDescription())
                .category(request.getCategory())
                .budget(request.getBudget())
                .platform(request.getPlatform())
                .deadline(request.getDeadline())
                .status("OPEN")
                .advertiser(advertiser)
                .build();

        campaignRepository.save(campaign);
        return "Campaign created successfully";
    }

    public List<CampaignResponse> getAdvertiserCampaigns(String email) {
        User advertiser = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("Advertiser not found"));

        return campaignRepository.findByAdvertiser(advertiser)
                .stream()
                .map(c -> CampaignResponse.builder()
                        .id(c.getId())
                        .title(c.getTitle())
                        .description(c.getDescription())
                        .category(c.getCategory())
                        .budget(c.getBudget())
                        .platform(c.getPlatform())
                        .deadline(c.getDeadline())
                        .status(c.getStatus())
                        .advertiserName(c.getAdvertiser().getName())
                        .build())
                .toList();
    }

    public List<CampaignResponse> getOpenCampaigns() {
        return campaignRepository.findByStatus("OPEN")
                .stream()
                .map(c -> CampaignResponse.builder()
                        .id(c.getId())
                        .title(c.getTitle())
                        .description(c.getDescription())
                        .category(c.getCategory())
                        .budget(c.getBudget())
                        .platform(c.getPlatform())
                        .deadline(c.getDeadline())
                        .status(c.getStatus())
                        .advertiserName(c.getAdvertiser().getName())
                        .build())
                .toList();
    }

    public String applyToCampaign(String email, ApplyCampaignRequest request) {
        User influencer = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("User not found"));

        if (!influencer.getRole().name().equals("INFLUENCER")) {
            throw new RuntimeException("Only influencers can apply");
        }

        Campaign campaign = campaignRepository.findById(request.getCampaignId())
                .orElseThrow(() -> new RuntimeException("Campaign not found"));

        CampaignApplication application = CampaignApplication.builder()
                .campaign(campaign)
                .influencer(influencer)
                .message(request.getMessage())
                .status("PENDING")
                .appliedAt(LocalDateTime.now())
                .build();

        campaignApplicationRepository.save(application);
        return "Application submitted";
    }

    public List<ApplicationResponse> getCampaignApplications(Long campaignId, String email) {
        User advertiser = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("User not found"));

        Campaign campaign = campaignRepository.findById(campaignId)
                .orElseThrow(() -> new RuntimeException("Campaign not found"));

        if (!campaign.getAdvertiser().getId().equals(advertiser.getId())) {
            throw new RuntimeException("You are not the owner of this campaign");
        }

        return campaignApplicationRepository.findByCampaignId(campaignId)
                .stream()
                .map(app -> ApplicationResponse.builder()
                        .applicationId(app.getId())
                        .influencerName(app.getInfluencer().getName())
                        .influencerEmail(app.getInfluencer().getEmail())
                        .message(app.getMessage())
                        .status(app.getStatus())
                        .appliedAt(app.getAppliedAt())
                        .build())
                .toList();
    }

    public String acceptApplication(Long applicationId, String email) {
        User advertiser = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("User not found"));

        CampaignApplication application = campaignApplicationRepository.findById(applicationId)
                .orElseThrow(() -> new RuntimeException("Application not found"));

        if (!application.getCampaign().getAdvertiser().getId().equals(advertiser.getId())) {
            throw new RuntimeException("You are not the owner of this campaign");
        }

        application.setStatus("ACCEPTED");
        campaignApplicationRepository.save(application);
        return "Influencer accepted for campaign";
    }

    public String rejectApplication(Long applicationId, String email) {
        User advertiser = userRepository.findByEmail(email)
                .orElseThrow(() -> new RuntimeException("User not found"));

        CampaignApplication application = campaignApplicationRepository.findById(applicationId)
                .orElseThrow(() -> new RuntimeException("Application not found"));

        if (!application.getCampaign().getAdvertiser().getId().equals(advertiser.getId())) {
            throw new RuntimeException("You are not the owner of this campaign");
        }

        application.setStatus("REJECTED");
        campaignApplicationRepository.save(application);
        return "Application rejected";
    }
}