package com.adnexa.controller;

import java.util.List;

import org.springframework.security.access.prepost.PreAuthorize;
import org.springframework.web.bind.annotation.*;

import com.adnexa.dto.InfluencerCardResponse;
import com.adnexa.dto.InfluencerSearchRequest;
import com.adnexa.service.InfluencerSearchService;

import lombok.RequiredArgsConstructor;

@RestController
@RequestMapping("/api/advertiser/influencers")
@RequiredArgsConstructor
public class InfluencerSearchController {

    private final InfluencerSearchService influencerSearchService;

    @GetMapping("/search")
    @PreAuthorize("hasRole('ADVERTISER')")
    public List<InfluencerCardResponse> searchInfluencers(InfluencerSearchRequest request) {
        return influencerSearchService.searchInfluencers(request);
    }
}